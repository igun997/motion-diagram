    { "at": 16,  "type": "reveal-node", "target": "orders" },
    { "at": 24,  "type": "reveal-node", "target": "pay" },
    { "at": 32,  "type": "reveal-node", "target": "db" },
    { "at": 40,  "type": "reveal-node", "target": "cache" },

    { "at": 52,  "type": "reveal-edge", "target": "web_gw" },
    { "at": 64,  "type": "reveal-edge", "target": "gw_orders" },
    { "at": 74,  "type": "reveal-edge", "target": "orders_pay" },
    { "at": 84,  "type": "reveal-edge", "target": "orders_db" },
